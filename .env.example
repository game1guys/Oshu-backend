PORT=3001
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Dev OTP bypass: server completes verifyOtp and returns tokens (fixes Android emulator TLS/fetch issues)
ALLOW_DEV_OTP_BYPASS=true

# Aadhaar: mock = in-memory OTP (any 6 digits). Production needs a licensed UIDAI ASP — not a public UIDAI REST API.
AADHAAR_KYC_MODE=mock

# Gemini OCR (server-side). Optional model override.
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash
